                <booleanValue>true</booleanValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Refund_Type__c</field>
            <value>
                <stringValue>CREDIT</stringValue>
            </value>
        </inputAssignments>
        <object>Order__c</object>
    </recordUpdates>
    <recordUpdates>
        <name>Payment_Refunded_in_Satus</name>
