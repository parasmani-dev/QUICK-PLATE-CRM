                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Refund_Approved__c</field>
            <operator>NotEqualTo</operator>
            <value>
                <elementReference>$Record__Prior.Order__r.Refund_Approved__c</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Payment_Status__c</field>
            <value>
                <stringValue>REFUNDED</stringValue>
            </value>
        </inputAssignments>
        <object>Order__c</object>
    </recordUpdates>
    <recordUpdates>
        <name>Service_Team_Approved_Refund</name>
        <label>Service Team Approved Refund</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Refund_Recommended__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Refund_Recommended__c</field>
