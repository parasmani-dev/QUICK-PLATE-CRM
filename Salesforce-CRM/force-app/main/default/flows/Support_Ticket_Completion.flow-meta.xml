        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Update_Ticket_Close_Time</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Refund_Approved__c</field>
