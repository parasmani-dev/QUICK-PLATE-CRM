<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <name>Main_Decision</name>
        <label>Main Decision</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Update</defaultConnectorLabel>
        <rules>
            <name>update_Finance_Status</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Refund_Recommended__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Refund_Recommended__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Service_Team_Approved_Refund</targetReference>
            </connector>
            <label>update Finance Status</label>
        </rules>
        <rules>
            <name>Update_Closed_Ticket_Time</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Ticket_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>CLOSED</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Ticket_Status__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>CLOSED</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Payment_Refunded_in_Satus</targetReference>
            </connector>
            <label>Update Closed Ticket Time</label>
        </rules>
        <rules>
            <name>Update_Finance_Status_by_Finance_Team</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Finance_Approval_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>APPROVED</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Finance_Approval_Status__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>APPROVED</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Order_Support_Ticket_Update</targetReference>
            </connector>
            <label>Update Finance Status by Finance Team</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>Balance</name>
        <dataType>Currency</dataType>
        <expression>ABS({!Getting_Credits.Available_Amount__c} + {!$Record.Recommended_Refund_Amount__c})</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <description>Adding Expiry date to Next 3 months Time</description>
        <name>Expiry_Date</name>
        <dataType>DateTime</dataType>
        <expression>ADDMONTHS(NOW(), 3)</expression>
    </formulas>
    <interviewLabel>Support Ticket Completion {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Support Ticket Completion</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
