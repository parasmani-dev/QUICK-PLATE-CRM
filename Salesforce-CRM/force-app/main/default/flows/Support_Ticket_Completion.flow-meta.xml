    <recordUpdates>
        <name>Order_Support_Ticket_Update</name>
        <label>Order-Support Ticket Update</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Create_Refund_Payment</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Order__r.Id</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Refund_Amount__c</field>
            <value>
                <elementReference>$Record.Recommended_Refund_Amount__c</elementReference>
