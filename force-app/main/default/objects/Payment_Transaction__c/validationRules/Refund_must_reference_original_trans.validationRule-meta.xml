<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Refund_must_reference_original_trans</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  ISPICKVAL(Transaction_Type__c, &quot;REFUND&quot;),
  ISBLANK(Linked_Original_Transaction__c)
)</errorConditionFormula>
    <errorMessage>Refund transactions must reference the original payment.</errorMessage>
</ValidationRule>
