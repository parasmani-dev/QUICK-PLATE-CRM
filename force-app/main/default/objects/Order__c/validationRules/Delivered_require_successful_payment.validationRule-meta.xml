<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Delivered_require_successful_payment</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  ISPICKVAL(Order_Status__c, &quot;DELIVERED&quot;),
  NOT(ISPICKVAL(Payment_Status__c, &quot;PAID&quot;))
)</errorConditionFormula>
    <errorDisplayField>Payment_Status__c</errorDisplayField>
    <errorMessage>Delivered Orders requires Successful Payment</errorMessage>
</ValidationRule>
