<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>InActive_Restaurant_Cannot_Take_Orders</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  ISPICKVAL(Order_Status__c, &quot;CREATED&quot;),
  Restaurant__r.Is_Active__c = FALSE
)</errorConditionFormula>
    <errorMessage>Orders cannot be created for inactive restaurants</errorMessage>
</ValidationRule>
