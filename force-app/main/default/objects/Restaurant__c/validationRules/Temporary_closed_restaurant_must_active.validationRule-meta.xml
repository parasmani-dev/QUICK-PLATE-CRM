<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Temporary_closed_restaurant_must_active</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  Is_Temporarily_Closed__c = TRUE,
  Is_Active__c = FALSE
)</errorConditionFormula>
    <errorMessage>Only active restaurants can be temporarily closed.</errorMessage>
</ValidationRule>
