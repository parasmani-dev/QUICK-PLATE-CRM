<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <allowRecall>false</allowRecall>
    <allowedSubmitters>
        <submitter>Support_Agent</submitter>
        <type>role</type>
    </allowedSubmitters>
    <allowedSubmitters>
        <submitter>quickplate.demo@gmail.com</submitter>
        <type>user</type>
    </allowedSubmitters>
    <allowedSubmitters>
        <submitter>varunshiyam2006.b784368829b4@agentforce.com</submitter>
        <type>user</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>Case_No__c</field>
        <field>Name</field>
        <field>Owner</field>
        <field>Recommended_Refund_Amount__c</field>
        <field>Resolution_Notes__c</field>
        <field>Investigation_Notes__c</field>
        <field>Customer_Issue_Count__c</field>
        <field>Priority__c</field>
        <field>Ticket_Status__c</field>
        <field>Order__c</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>Finance_Approval_Queue</name>
                <type>queue</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <label>Finance Approval</label>
        <name>Finance_Approval</name>
    </approvalStep>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <entryCriteria>
        <criteriaItems>
            <field>Support_Ticket__c.Finance_Approval_Status__c</field>
            <operation>equals</operation>
            <value>PENDING_FINANCE_APPROVAL</value>
        </criteriaItems>
        <criteriaItems>
            <field>Support_Ticket__c.Refund_Recommended__c</field>
            <operation>equals</operation>
            <value>True</value>
        </criteriaItems>
    </entryCriteria>
    <finalApprovalActions>
        <action>
            <name>Update_the_Finance_Approval_Status</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>update_Ticket_Status</name>
            <type>FieldUpdate</type>
        </action>
    </finalApprovalActions>
    <finalApprovalRecordLock>false</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>Update_Finance_Approval_Status</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>update_Ticket_Status_Neg</name>
            <type>FieldUpdate</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <label>Refund Approval to Finance Team</label>
    <processOrder>1</processOrder>
    <recordEditability>AdminOrCurrentApprover</recordEditability>
    <showApprovalHistory>false</showApprovalHistory>
</ApprovalProcess>
